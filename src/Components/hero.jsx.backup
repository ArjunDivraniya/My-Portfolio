
import React, { useState, useEffect } from "react";
import { motion, useMotionValue, useTransform, useSpring, AnimatePresence } from "framer-motion";
import { TypeAnimation } from "react-type-animation";
import { FaGithub, FaCodeBranch, FaTrophy, FaCode, FaFire, FaRadiation, FaMedal, FaStack, FaInstagram, FaCheckCircle } from "react-icons/fa";
import { MdRadio } from "react-icons/md";

// Floating Interactive Card Component
const FloatingCard = ({ icon: Icon, title, subtitle, delay, color = "purple", x: initialX, y: initialY }) => {
  const cardX = useMotionValue(initialX);
  const cardY = useMotionValue(initialY);
  
  return (
    <motion.div
      className={`absolute bg-black/40 backdrop-blur-xl border-2 border-${color}-500/50 rounded-2xl p-4 cursor-grab active:cursor-grabbing shadow-2xl hover:shadow-${color}-500/50 transition-shadow`}
      style={{
        x: cardX,
        y: cardY,
        boxShadow: `0 25px 50px -12px rgba(${color === 'yellow' ? '234, 179, 8' : '168, 85, 247'}, 0.5)`,
      }}
      initial={{ opacity: 0, scale: 0 }}
      animate={{ 
        opacity: 1, 
        scale: 1,
        y: [initialY, initialY - 15, initialY],
      }}
      transition={{ 
        opacity: { duration: 0.8, delay, type: "spring" },
        scale: { duration: 0.8, delay, type: "spring" },
        y: {
          duration: 3 + delay * 0.5,
          repeat: Infinity,
          ease: "easeInOut",
        },
      }}
      drag
      dragConstraints={{ left: -150, right: 150, top: -150, bottom: 150 }}
      dragElastic={0.5}
      whileHover={{ 
        scale: 1.1, 
        borderColor: color === 'yellow' ? "rgba(234, 179, 8, 1)" : "rgba(168, 85, 247, 1)",
      }}
    >
      <div className="flex items-center gap-3 min-w-max">
        <Icon className={`text-${color}-400 text-2xl drop-shadow-lg`} />
        <div>
          <p className={`text-${color}-400 font-bold text-lg drop-shadow-md`}>{title}</p>
          <p className="text-gray-300 text-xs">{subtitle}</p>
        </div>
      </div>
    </motion.div>
  );
};

// Particle Background Component
const ParticleField = () => {
  const particles = Array.from({ length: 30 }, (_, i) => ({
    id: i,
    x: Math.random() * 100,
    y: Math.random() * 100,
    size: Math.random() * 2 + 0.5,
    duration: Math.random() * 10 + 15,
  }));

  return (
    <div className="absolute inset-0 overflow-hidden">
      {particles.map((particle) => (
        <motion.div
          key={particle.id}
          className="absolute bg-white rounded-full opacity-30"
          style={{
            width: particle.size,
            height: particle.size,
            left: `${particle.x}%`,
            top: `${particle.y}%`,
          }}
          animate={{
            y: [0, -200, 0],
            x: [0, Math.random() > 0.5 ? 50 : -50, 0],
            opacity: [0.3, 0.7, 0.3],
          }}
          transition={{
            duration: particle.duration,
            repeat: Infinity,
            ease: "easeInOut",
          }}
        />
      ))}
    </div>
  );
};

const Hero = () => {
  const [mounted, setMounted] = useState(false);
  const mouseX = useMotionValue(0);
  const mouseY = useMotionValue(0);
  
  // Smooth mouse tracking
  const springConfig = { damping: 20, stiffness: 100 };
  const x = useSpring(mouseX, springConfig);
  const y = useSpring(mouseY, springConfig);
  
  // ENHANCED - More dramatic parallax depths for stronger 3D effect
  const photoRotateX = useTransform(y, [-500, 500], [25, -25]);
  const photoRotateY = useTransform(x, [-500, 500], [-25, 25]);
  const photoZ = useTransform(x, [-500, 500], [-50, 50]);
  
  // Text 3D transforms
  const textRotateX = useTransform(y, [-500, 500], [10, -10]);
  const textRotateY = useTransform(x, [-500, 500], [-10, 10]);
  const textZ = useTransform(x, [-500, 500], [0, 30]);
  
  // Badges with different Z-depth
  const badge1X = useTransform(x, [-500, 500], [-60, 60]);
  const badge1Y = useTransform(y, [-500, 500], [-60, 60]);
  const badge1Z = useTransform(x, [-500, 500], [100, 0]);
  
  const badge2X = useTransform(x, [-500, 500], [60, -60]);
  const badge2Y = useTransform(y, [-500, 500], [40, -40]);
  const badge2Z = useTransform(x, [-500, 500], [80, -20]);
  
  const badge3X = useTransform(x, [-500, 500], [-40, 40]);
  const badge3Y = useTransform(y, [-500, 500], [60, -60]);
  const badge3Z = useTransform(x, [-500, 500], [60, -40]);
  
  // Interactive spotlight gradient
  const spotlightX = useTransform(x, [-500, 500], ['20%', '80%']);

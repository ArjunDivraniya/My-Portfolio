// Enhanced Magnetic Button Component with 3D Lift Effect
const MagneticButton = () => {
  const [isHovered, setIsHovered] = useState(false);
  const mouseX = useMotionValue(0);
  const mouseY = useMotionValue(0);
  
  const buttonX = useTransform(mouseX, [-100, 100], [-20, 20]);
  const buttonY = useTransform(mouseY, [-100, 100], [-20, 20]);

  const handleMouseMove = (e) => {
    const rect = e.currentTarget.getBoundingClientRect();
    const centerX = rect.left + rect.width / 2;
    const centerY = rect.top + rect.height / 2;
    mouseX.set(e.clientX - centerX);
    mouseY.set(e.clientY - centerY);
  };

  const handleMouseLeave = () => {
    mouseX.set(0);
    mouseY.set(0);
    setIsHovered(false);
  };

  return (
    <motion.div
      className="inline-block"
      onMouseMove={handleMouseMove}
      onMouseEnter={() => setIsHovered(true)}
      onMouseLeave={handleMouseLeave}
    >
      <motion.a
        href="#contact"
        className="relative inline-block px-10 py-5 bg-gradient-to-r from-yellow-500 to-yellow-600 text-black font-bold text-lg rounded-2xl overflow-hidden group shadow-xl"
        style={{ x: buttonX, y: buttonY }}
        whileHover={{ 
          y: -10,
          rotateX: 15,
          rotateY: 5,
          scale: 1.05,
          boxShadow: "0 30px 60px -15px rgba(234, 179, 8, 0.8), 0 0 40px rgba(234, 179, 8, 0.6)"
        }}
        whileTap={{ scale: 0.95, y: 0 }}
        transition={{ duration: 0.3, type: "spring" }}
      >
        {/* Background Animation Layer */}
        <motion.span
          className="absolute inset-0 bg-gradient-to-r from-purple-600 to-yellow-500"
          initial={{ x: "-100%" }}
          animate={{ x: isHovered ? "0%" : "-100%" }}
          transition={{ duration: 0.3 }}
        />
        
        {/* 3D Lift Shadow */}
        <motion.div
          className="absolute inset-0 rounded-2xl"
          style={{
            background: "radial-gradient(ellipse at center, rgba(0,0,0,0.3) 0%, transparent 70%)",
            transform: "translateZ(-20px)",
          }}
          animate={{
            scaleY: isHovered ? 0.2 : 0.05,
            opacity: isHovered ? 1 : 0.3,
          }}
          transition={{ duration: 0.3 }}
        />
        
        <span className="relative z-10 flex items-center gap-2">
          Get In Touch
          <motion.span
            animate={{ x: isHovered ? 8 : 0, rotate: isHovered ? 20 : 0 }}
            transition={{ duration: 0.3 }}
          >
            →
          </motion.span>
        </span>
      </motion.a>
    </motion.div>
  );
};

export default Hero;
